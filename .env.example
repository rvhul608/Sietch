# NitroStack Configuration
NITRO_LOG_LEVEL=info
NITROSTACK_APP_MODE=openai

# ============================================================
# Groq Configuration (used by analyze-policy for document parsing)
# ============================================================
# Get a free API key at: https://console.groq.com/keys
# NOTE: check NitroStack docs — NITROSTACK_APP_MODE=openai above may
# mean the framework expects an OpenAI-compatible base URL rather than
# a raw Groq SDK call. Groq's API is OpenAI-compatible, so this might
# just need a base URL override rather than a separate client.
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Server Transport Configuration (Optional)
# ============================================================
# MCP_TRANSPORT_TYPE: Toggles transport mode. Values: stdio | http | dual.
# Defaults to 'stdio' in development and 'dual' in production/NODE_ENV=production.
# ============================================================
# MCP_TRANSPORT_TYPE=stdio
# PORT=3000
# HOST=localhost
# ENABLE_CORS=true

# Mapbox Configuration (Optional)
# ============================================================
# The map widget uses Mapbox GL for interactive maps.
# Get a free API key at: https://www.mapbox.com/
# ============================================================

# Your Mapbox Public Token (starts with pk.)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
